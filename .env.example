# Example environment file
# Copy this to .env and modify as needed

# Windows Version
VERSION=11

# KVM Acceleration (Y/N)
KVM=N

# Resources
RAM_SIZE=64G
CPU_CORES=16
DISK_SIZE=200G

# Credentials
USERNAME=Admin
PASSWORD=Admin123

# Disk Settings
DISK_IO=threads
DISK_CACHE=writeback
DISK_TYPE=blk
DISK_FMT=raw

# Features
SAMBA=Y
TPM=N
SMM=N
